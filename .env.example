# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bureau_user:bureau_pass@localhost:5432/currency_bureau"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174

# ── Admin auth (simple hardcoded credentials for the internal admin app) ───────
ADMIN_USER=admin
ADMIN_PASS=admin123

# ── Sentry error monitoring ────────────────────────────────────────────────────
# Backend (Node.js) DSN — injected at container runtime
SENTRY_DSN=

# Frontend (Vite) DSN — baked into the JS bundle at build time
# Set VITE_SENTRY_DSN in your build environment (CI build-args or local .env)
VITE_SENTRY_DSN=

# ── Rate engine ───────────────────────────────────────────────────────────────
# How long (seconds) to cache rates before re-fetching from Frankfurter API
RATE_TTL_SECONDS=60

# Bureau margin multipliers (applied to the live market rate)
# BUY_MARGIN  < 1  → bureau pays less than market when buying foreign from client
# SELL_MARGIN > 1  → bureau charges more than market when selling foreign to client
BUY_MARGIN=0.985
SELL_MARGIN=1.015

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=onboarding@resend.dev
